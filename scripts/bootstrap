#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

if [ -f "Brewfile" ] && [ "$(uname -s)" = "Darwin" ] && [ "$SKIP_BREW" != "1" ] && [ -t 0 ]; then
  brew bundle check >/dev/null 2>&1 || {
    echo -n "==> Install Homebrew dependencies? (y/N): "
    read -r response
    case "$response" in
      [yY][eE][sS]|[yY])
        brew bundle
        ;;
      *)
        ;;
    esac
    echo
  }
fi

echo "==> Installing Node dependencies…"

require_pnpm_config() {
  key="$1"
  expected="$2"
  actual="$(corepack pnpm config get "$key")"

  if [ "$actual" != "$expected" ]; then
    echo "ERROR: expected pnpm config '$key' to be '$expected', got '$actual'"
    exit 1
  fi
}

echo "==> Verifying pnpm supply-chain policy…"
require_pnpm_config minimum-release-age 10080
require_pnpm_config block-exotic-subdeps true
require_pnpm_config strict-dep-builds true
if ! corepack pnpm config list | grep -Fxq 'only-built-dependencies[]=@swc/core'; then
  echo "ERROR: expected pnpm to allow dependency builds only for @swc/core"
  exit 1
fi

if [ "${CI:-}" = "true" ]; then
  corepack pnpm install --frozen-lockfile
else
  corepack pnpm install
fi
